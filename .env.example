# Public (exposed to the browser)
# Production: https://your-project.vercel.app or custom domain
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional display name (defaults to Trou)
# NEXT_PUBLIC_SITE_NAME=Trou

# Set to "true" only if couple invites should appear in Google search
NEXT_PUBLIC_ALLOW_INVITE_INDEXING=false

# Vercel sets automatically — do not commit:
# VERCEL_URL=
# VERCEL_ENV=production
